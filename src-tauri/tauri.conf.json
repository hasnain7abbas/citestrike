{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "CiteStrike",
  "version": "0.2.1",
  "identifier": "com.citestrike.app",
  "build": {
    "frontendDist": "../build",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "CiteStrike",
        "label": "main",
        "width": 960,
        "height": 640,
        "minWidth": 780,
        "minHeight": 500,
        "resizable": true,
        "decorations": false,
        "transparent": false,
        "center": true,
        "visible": true,
        "alwaysOnTop": false,
        "skipTaskbar": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {}
}
